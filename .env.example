# Copy this file to .env and fill in local values.
# Never commit your real .env file.

HOST=127.0.0.1
PORT=8010

RAPIDAPI_KEY=your-rapidapi-key
FLASHAPI_HOST=flashapi1.p.rapidapi.com
FLASHAPI_BASE_URL=https://flashapi1.p.rapidapi.com
FLASHAPI_ENDPOINT_PATH=ig/info_username/
FLASHAPI_USERNAME_PARAM=username
FLASHAPI_NOCORS=false
FLASHAPI_TIMEOUT_SECONDS=15

# Optional future integrations
TWITTER_BEARER_TOKEN=
TELEGRAM_BOT_TOKEN=
DATABASE_URL=postgresql+psycopg://osint:osint@localhost:5432/osint
REDIS_URL=redis://localhost:6379/0
